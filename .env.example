# Tee Sniper Configuration
# Copy this file to .env and fill in the values

# Required: Booking site credentials
TS_USERNAME=your-username
TS_PIN=your-pin
TS_BASEURL=https://your-golf-course.example.com/

# Required: Apprise notification URL
# See https://github.com/caronc/apprise for supported notification services
# Examples:
#   - Apprise API: http://localhost:8000/notify
#   - Twilio SMS: twilio://AccountSid:AuthToken@FromPhone/ToPhone
#   - Email: mailto://user:password@gmail.com
#   - Slack: slack://TokenA/TokenB/TokenC
APPRISE_URL=http://localhost:8000/notify

# Required: Booking parameters
TS_DAYS_AHEAD=7
TS_TIME_START=09:00
TS_TIME_END=17:00

# Optional: Retry configuration (default: 5)
TS_RETRIES=5

# Optional: Dry run mode (set to true for testing without booking)
TS_DRY_RUN=false

# Optional: Playing partners (comma-separated IDs)
# TS_PARTNERS=partner1,partner2

# Optional: Log level (debug, info, warn, error)
TS_LOG_LEVEL=info
